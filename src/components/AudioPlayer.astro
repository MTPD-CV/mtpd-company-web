---
// AudioPlayer.astro
---

<div id="audio-widget" class="audio-widget">
  <button id="audio-toggle" class="audio-btn" aria-label="Play/Pause Background Music">
    <!-- Arrow Icon (Visible when tucked) -->
    <svg id="icon-arrow" class="icon-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
    <!-- Muted Icon -->
    <svg id="icon-muted" class="icon-muted" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
      <line x1="23" y1="9" x2="17" y2="15"></line>
      <line x1="17" y1="9" x2="23" y2="15"></line>
    </svg>
    <!-- Playing Icon -->
    <svg id="icon-playing" class="icon-playing is-js-hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
      <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
      <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
    </svg>
  </button>
  <div class="audio-info">
    <div class="marquee-container">
      <span id="audio-title">Klik untuk memutar musik latar...</span>
    </div>
  </div>
</div>

<audio id="bgm-player" preload="metadata" loop></audio>

<script>
  // Single Track Definition
  const playlist = [
    { file: '/audio/cobblestone-village.mp3', title: 'Medieval Music - Cobblestone Village' }
  ];

  let currentTrack = 0;
  let isPlaying = false;
  let collapseTimeout;

  const audioEl = document.getElementById('bgm-player') as HTMLAudioElement;
  const toggleBtn = document.getElementById('audio-toggle');
  const titleEl = document.getElementById('audio-title');
  const iconMuted = document.getElementById('icon-muted');
  const iconPlaying = document.getElementById('icon-playing');
  const widgetEl = document.getElementById('audio-widget');

  // Load first track but DO NOT PLAY (Respect Browser Autoplay Policy)
  if (audioEl && playlist.length > 0) {
    audioEl.src = playlist[currentTrack].file;
    audioEl.volume = 0.5; // Set volume to 50%
  }

  // Toggle Play/Pause
  toggleBtn?.addEventListener('click', () => {
    if (!audioEl) return;

    if (isPlaying) {
      audioEl.pause();
      isPlaying = false;
      widgetEl?.classList.remove('is-expanded', 'is-playing');
      clearTimeout(collapseTimeout); // Batalkan timer jika dijeda
      updateUI();
    } else {
      audioEl.play().then(() => {
        isPlaying = true;
        widgetEl?.classList.add('is-expanded', 'is-playing');
        updateUI();

        // Fitur UX: Auto-Collapse laci setelah 4 detik agar tidak menutupi layar
        clearTimeout(collapseTimeout);
        collapseTimeout = setTimeout(() => {
          widgetEl?.classList.remove('is-expanded');
        }, 4000);

      }).catch(err => {
        console.error("Audio playback failed:", err);
      });
    }
  });

  function updateUI() {
    if (isPlaying) {
      iconMuted?.classList.add('is-js-hidden');
      iconPlaying?.classList.remove('is-js-hidden');
      if (titleEl) titleEl.innerHTML = `🎵 Memutar: ${playlist[currentTrack].title} <span class="audio-source">Source by YouTube</span>`;
    } else {
      iconPlaying?.classList.add('is-js-hidden');
      iconMuted?.classList.remove('is-js-hidden');
      if (titleEl) titleEl.innerHTML = `BGM Jeda - ${playlist[currentTrack].title} <span class="audio-source">Source by YouTube</span>`;
    }
  }
</script>

<style>
  .audio-widget {
    position: fixed;
    bottom: 30px;
    left: 0; /* Di Kiri Bawah menempel layar */
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 6px 16px 6px 6px; /* Padding kiri lebih kecil */
    border-radius: 0 50px 50px 0; /* Rata di kiri, melengkung di kanan */
    box-shadow: 4px 4px 15px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-left: none;
    max-width: 250px;
    /* Lebar tombol(36) + pad kiri(6) + sedikit ruang(10) = 52px yang terlihat */
    transform: translateX(calc(-100% + 52px));
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .audio-widget:hover, .audio-widget.is-expanded {
    transform: translateX(0);
  }

  .audio-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--color-primary);
    color: white; /* Panah & Speaker warna putih */
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.3s ease;
    box-shadow: 2px 0 5px rgba(0,0,0,0.1);
  }

  .audio-widget:hover .audio-btn,
  .audio-widget.is-expanded .audio-btn {
    background: var(--color-primary-light);
  }

  /* Indikator Denyut (Breathing Glow) saat menyembunyi & menyala */
  .audio-widget.is-playing:not(:hover):not(.is-expanded) .audio-btn {
    animation: breathingGlow 2s ease-in-out infinite alternate;
  }

  @keyframes breathingGlow {
    0% { box-shadow: 2px 0 5px rgba(0,0,0,0.1); }
    100% { box-shadow: 0 0 20px rgba(30, 90, 34, 0.85); }
  }

  /* Logika Tampilan Ikon yang Sangat Kuat (Anti-Bocor) */
  .audio-btn svg {
    display: none; /* Sembunyikan semua SVG secara bawaan */
  }

  /* Tampilkan panah HANYA saat posisi sembunyi (tucked) */
  .audio-widget:not(:hover):not(.is-expanded) .audio-btn #icon-arrow {
    display: block;
  }

  /* Tampilkan ikon status (Speaker) HANYA saat ditarik/hovered */
  .audio-widget:hover .audio-btn #icon-muted:not(.is-js-hidden),
  .audio-widget.is-expanded .audio-btn #icon-muted:not(.is-js-hidden),
  .audio-widget:hover .audio-btn #icon-playing:not(.is-js-hidden),
  .audio-widget.is-expanded .audio-btn #icon-playing:not(.is-js-hidden) {
    display: block;
  }

  .is-js-hidden {
    display: none !important;
  }

  .audio-info {
    overflow: hidden;
    white-space: nowrap;
    width: 150px;
  }

  .marquee-container {
    display: inline-block;
    padding-left: 100%;
    animation: marquee 15s linear infinite;
  }

  #audio-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-main);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .audio-source {
    font-size: 0.65rem;
    font-weight: 600;
    color: #666;
    background: rgba(0, 0, 0, 0.06);
    padding: 2px 8px;
    border-radius: 12px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  @keyframes marquee {
    0% { transform: translate(0, 0); }
    100% { transform: translate(-100%, 0); }
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .audio-widget {
      bottom: 20px;
      /* Pastikan left tetap 0 di mobile agar drawer menempel */
      left: 0;
      max-width: 200px;
      transform: translateX(calc(-100% + 42px)); /* Menyembunyikan teks sepenuhnya */
    }
    
    .audio-widget:hover, .audio-widget.is-expanded {
      transform: translateX(0);
    }

    .audio-info {
      width: 110px;
    }
  }
</style>
