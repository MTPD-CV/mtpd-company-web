---
// WheatIntro.astro
---

<div id="wheat-splash" class="wheat-splash-container">
  <img src="/images/rice-grain.svg" alt="" class="wheat-stalk wheat-left" />
  <img src="/images/rice-grain.svg" alt="" class="wheat-stalk wheat-right" />
</div>

<script>
  // Hapus komponen dari memori layar (DOM) setelah animasi selesai
  // agar klik pengunjung tidak terhalangi (Performance & UX optimization)
  document.addEventListener("DOMContentLoaded", () => {
    const splash = document.getElementById('wheat-splash');
    if (splash) {
      setTimeout(() => {
        splash.remove();
      }, 7500); // Hapus 0.5 detik setelah animasi CSS (7s) usai
    }
  });
</script>

<style>
  .wheat-splash-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none; /* Memastikan klik tembus ke tombol di belakangnya */
    z-index: 99999; /* Muncul paling depan */
    overflow: hidden;
  }

  .wheat-stalk {
    position: absolute;
    bottom: -15vh;
    height: 55vh;
    max-height: 400px;
    opacity: 0;
    /* CSS Filter Generator: Mengubah warna asli gambar SVG menjadi Forest Green (#1e5a22) */
    filter: invert(29%) sepia(45%) saturate(718%) hue-rotate(76deg) brightness(97%) contrast(89%);
    animation-duration: 7s;
    animation-timing-function: ease-in-out; 
    animation-fill-mode: forwards;
  }

  /* Sebelah Kiri */
  .wheat-left {
    left: -10vw;
    transform-origin: bottom center;
    animation-name: swayLeft;
  }

  /* Sebelah Kanan */
  .wheat-right {
    right: -10vw;
    transform-origin: bottom center;
    animation-name: swayRight;
  }

  /* KOREOGRAFI ANIMASI KIRI (Tumbuh & Mengayun) */
  @keyframes swayLeft {
    0% { 
        opacity: 0; 
        transform: scale(0.6) rotate(20deg); 
    }
    15% { /* Detik 1.05: Mekar penuh di sudut */
        opacity: 1; 
        transform: scale(1) rotate(45deg); 
    }
    30% { /* Mengayun ke kanan */
        opacity: 1; 
        transform: scale(1) rotate(48deg); 
    }
    50% { /* Mengayun ke kiri */
        opacity: 1; 
        transform: scale(1) rotate(43deg); 
    }
    70% { /* Mengayun santai */
        opacity: 1; 
        transform: scale(1) rotate(46deg); 
    }
    85% { /* Bersiap menghilang */
        opacity: 1; 
        transform: scale(1) rotate(45deg); 
    }
    100% { /* Memudar dan mengecil ke sudut */
        opacity: 0; 
        transform: scale(0.6) rotate(60deg); 
    }
  }

  /* KOREOGRAFI ANIMASI KANAN */
  @keyframes swayRight {
    0% { 
        opacity: 0; 
        transform: scaleX(-1) scale(0.6) rotate(20deg); 
    }
    15% { 
        opacity: 1; 
        transform: scaleX(-1) scale(1) rotate(45deg); 
    }
    30% { 
        opacity: 1; 
        transform: scaleX(-1) scale(1) rotate(48deg); 
    }
    50% { 
        opacity: 1; 
        transform: scaleX(-1) scale(1) rotate(43deg); 
    }
    70% { 
        opacity: 1; 
        transform: scaleX(-1) scale(1) rotate(46deg); 
    }
    85% { 
        opacity: 1; 
        transform: scaleX(-1) scale(1) rotate(45deg); 
    }
    100% { 
        opacity: 0; 
        transform: scaleX(-1) scale(0.6) rotate(60deg); 
    }
  }

  /* Mode Responsif untuk HP */
  @media (max-width: 768px) {
    .wheat-stalk {
      height: 40vh;
      bottom: -10vh;
    }
    .wheat-left { left: -15vw; }
    .wheat-right { right: -15vw; }
  }
</style>
