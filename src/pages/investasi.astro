---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Peluang Investasi | MATAPADI Smart Agriculture">
  <Navigation />
  
  <main class="invest-page">
    <div class="invest-header">
      <a href="/" class="back-btn">← Kembali ke Beranda</a>
      <h1>Peluang Investasi <span class="text-gradient">Pilot Project</span></h1>
      <p class="subtitle">Bergabunglah dalam revolusi Smart Farming pertama di Indonesia yang menggabungkan AI (YOLOv8) dan IoT untuk ketahanan pangan nasional.</p>
    </div>

    <section class="invest-section">
      <div class="section-card">
        <h2>1. Analisis Pasar</h2>
        
        <div class="market-item">
          <h3>a. Target Pasar</h3>
          <p>MATAPADI ditujukan untuk sektor pertanian padi yang membutuhkan solusi pengendalian hama burung secara efektif, otomatis, dan berbasis teknologi. Target pasar utama meliputi:</p>
          <ul class="styled-list">
            <li>Petani padi skala kecil dan menengah.</li>
            <li>Kelompok Tani (Poktan) dan Gabungan Kelompok Tani (Gapoktan).</li>
            <li>Koperasi pertanian.</li>
            <li>Perusahaan agribisnis dan perkebunan.</li>
            <li>Dinas Pertanian tingkat kabupaten/kota maupun provinsi.</li>
            <li>Program Smart Farming dan Digital Farming.</li>
            <li>Program CSR perusahaan yang bergerak di bidang pertanian.</li>
          </ul>
        </div>

        <div class="market-item">
          <h3>b. Potensi Pasar</h3>
          <p>Indonesia memiliki lebih dari <strong>10 juta hektar</strong> lahan sawah yang tersebar di berbagai wilayah. Sebagian besar lahan tersebut berpotensi mengalami gangguan hama burung terutama pada fase menjelang panen. Selain itu, tren transformasi digital pertanian dan penerapan Smart Farming terus meningkat sehingga menciptakan peluang pasar yang besar bagi solusi pertanian berbasis Artificial Intelligence dan Internet of Things.</p>
          <p>Dengan asumsi tahap awal mampu menjangkau 1% dari kelompok tani dan petani modern di Indonesia, MATAPADI memiliki peluang pasar yang sangat luas untuk dikembangkan secara nasional.</p>
        </div>

        <div class="market-item">
          <h3>c. Kebutuhan Pasar</h3>
          <p>Berdasarkan kondisi di lapangan, petani membutuhkan solusi yang:</p>
          <ul class="styled-list">
            <li>Mampu mengurangi kerugian hasil panen akibat serangan hama burung.</li>
            <li>Bekerja secara otomatis tanpa pengawasan terus-menerus.</li>
            <li>Mudah digunakan dan dipasang.</li>
            <li>Dapat dipantau dari jarak jauh.</li>
            <li>Memiliki biaya operasional yang rendah.</li>
            <li>Meningkatkan keamanan lahan pertanian.</li>
          </ul>
          <p class="highlight-box">MATAPADI hadir untuk memenuhi kebutuhan tersebut melalui integrasi teknologi AI, Computer Vision, dan IoT dalam satu sistem yang mudah digunakan oleh petani.</p>
        </div>
      </div>
    </section>

    <section class="invest-section">
      <div class="section-card">
        <h2>2. Analisis Kompetitor</h2>
        <div class="table-wrapper">
          <table class="competitor-table">
            <thead>
              <tr>
                <th>Aspek</th>
                <th>Metode Konvensional</th>
                <th class="mtpd-col">MATAPADI (Smart Farming)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Pengendalian Hama Burung</strong></td>
                <td>Orang-orangan sawah dan alat pengusir sederhana yang efektivitasnya menurun seiring waktu</td>
                <td class="mtpd-col highlight">Deteksi burung berbasis AI (YOLOv8) secara <em>real-time</em></td>
              </tr>
              <tr>
                <td><strong>Sistem Pengusiran</strong></td>
                <td>Kaleng, petasan, atau alat pengusir yang dioperasikan secara manual</td>
                <td class="mtpd-col highlight">Pengusiran otomatis menggunakan sirine, speaker ultrasonik, atau aktuator lainnya</td>
              </tr>
              <tr>
                <td><strong>Operasional</strong></td>
                <td>Memerlukan penjagaan dan pengawasan manusia</td>
                <td class="mtpd-col highlight">Bekerja otomatis selama 24 jam</td>
              </tr>
              <tr>
                <td><strong>Monitoring Jarak Jauh</strong></td>
                <td>Tidak tersedia</td>
                <td class="mtpd-col highlight">Dapat dipantau melalui smartphone atau komputer melalui internet</td>
              </tr>
              <tr>
                <td><strong>Keamanan Lahan</strong></td>
                <td>Pengawasan terbatas dan tidak terintegrasi</td>
                <td class="mtpd-col highlight">CCTV dan sensor gerak dengan notifikasi otomatis kepada pengguna</td>
              </tr>
              <tr>
                <td><strong>Teknologi</strong></td>
                <td>Konvensional</td>
                <td class="mtpd-col highlight">Berbasis Artificial Intelligence (AI) dan Internet of Things (IoT)</td>
              </tr>
              <tr>
                <td><strong>Efisiensi Biaya</strong></td>
                <td>Membutuhkan biaya tenaga kerja tambahan</td>
                <td class="mtpd-col highlight">Mengurangi biaya operasional dan kebutuhan penjaga sawah</td>
              </tr>
              <tr>
                <td><strong>Pengambilan Data</strong></td>
                <td>Tidak tersedia</td>
                <td class="mtpd-col highlight">Menyediakan data monitoring dan aktivitas sistem secara real-time</td>
              </tr>
              <tr>
                <td><strong>Respons Terhadap Ancaman</strong></td>
                <td>Bergantung pada kehadiran petani</td>
                <td class="mtpd-col highlight">Respons otomatis terhadap deteksi burung dan aktivitas mencurigakan</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="invest-section">
      <div class="section-card dark-card">
        <h2>3. Penawaran Investasi</h2>
        <p>Untuk mewujudkan implementasi awal MATAPADI dan membuktikan efektivitas teknologi di lapangan, kami membuka peluang investasi sebesar <strong>Rp15.000.000</strong> untuk pengembangan satu unit <em>pilot project</em>.</p>
        <p>Pendanaan ini akan digunakan untuk pengadaan komponen utama, proses perakitan perangkat, instalasi di lahan pertanian, pengujian sistem secara menyeluruh, serta penyempurnaan perangkat lunak berbasis Artificial Intelligence dan Internet of Things. Pilot project ini akan menjadi langkah strategis dalam memvalidasi kinerja MATAPADI dalam mendeteksi dan mengendalikan hama burung secara otomatis, sekaligus menunjukkan potensi komersial produk sebagai solusi Smart Farming yang inovatif, efisien, dan berkelanjutan bagi sektor pertanian Indonesia.</p>
        
        <h3 style="margin-top: 40px; margin-bottom: 20px;">Rencana Anggaran Biaya (RAB) Pilot Project</h3>
        <div class="table-wrapper">
          <table class="finance-table">
            <thead>
              <tr>
                <th width="10%">No</th>
                <th width="60%">Komponen</th>
                <th width="30%">Estimasi Biaya</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>1</td><td>Raspberry Pi 5 RAM 8 GB</td><td>Rp 5.700.000</td></tr>
              <tr><td>2</td><td>CCTV Hikvision 360°</td><td>Rp 800.000</td></tr>
              <tr><td>3</td><td>Speaker Outdoor</td><td>Rp 500.000</td></tr>
              <tr><td>4</td><td>Aki 12 Volt</td><td>Rp 450.000</td></tr>
              <tr><td>5</td><td>Router ZBTLink W2008</td><td>Rp 700.000</td></tr>
              <tr><td>6</td><td>Panel Surya dan Modul Controller</td><td>Rp 2.000.000</td></tr>
              <tr><td>7</td><td>LCD TFT I2C</td><td>Rp 250.000</td></tr>
              <tr><td>8</td><td>Sensor Gerak (PIR)</td><td>Rp 100.000</td></tr>
              <tr><td>9</td><td>Rangka Hollow dan Dudukan</td><td>Rp 1.000.000</td></tr>
              <tr><td>10</td><td>Box Panel dan Instalasi</td><td>Rp 500.000</td></tr>
              <tr><td>11</td><td>Pengembangan Software dan Integrasi Sistem</td><td>Rp 2.000.000</td></tr>
              <tr><td>12</td><td>Pengujian dan Implementasi Lapangan</td><td>Rp 1.000.000</td></tr>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="2" style="text-align: right;"><strong>Total Kebutuhan Dana</strong></td>
                <td class="total-amount">Rp 15.000.000</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <h3 style="margin-top: 40px; margin-bottom: 15px;">Target Implementasi</h3>
        <p>Melalui investasi ini, MATAPADI menargetkan:</p>
        <ul class="styled-list">
          <li>Tersedianya 1 unit MATAPADI yang siap digunakan di lahan pertanian.</li>
          <li>Pengujian performa deteksi burung berbasis YOLOv8 secara <em>real-time</em>.</li>
          <li>Pengujian sistem pengusiran otomatis berbasis ESP32.</li>
          <li>Pengujian monitoring jarak jauh melalui internet.</li>
          <li>Pengumpulan data lapangan sebagai dasar pengembangan produk komersial.</li>
        </ul>

        <div class="cta-container">
          <p style="margin-bottom: 20px; font-weight: 500;">Tertarik untuk merevolusi agrikultur Indonesia bersama kami?</p>
          <a href="https://wa.me/6285142608962?text=Halo%20Tim%20MATAPADI,%20saya%20tertarik%20dengan%20Peluang%20Investasi%20Pilot%20Project%20Rp15%20Juta." target="_blank" rel="noopener noreferrer" class="btn-wa">
            Hubungi via WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <!-- Simple Footer for internal pages -->
  <footer style="background: #111827; color: white; padding: 40px; text-align: center; margin-top: 60px;">
    <p>© 2026 MATAPADI Smart Agriculture Technology. All Rights Reserved.</p>
  </footer>
</Layout>

<style>
  .invest-page {
    max-width: 1000px;
    margin: 140px auto 0;
    padding: 0 5%;
  }

  .invest-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .back-btn {
    display: inline-block;
    margin-bottom: 30px;
    padding: 8px 16px;
    background: var(--color-bg-alt);
    color: var(--color-text-main);
    text-decoration: none;
    font-weight: 600;
    border-radius: 50px;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    border: 1px solid rgba(0,0,0,0.05);
  }

  .back-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: translateX(-3px);
  }

  .invest-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    margin-bottom: 20px;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .invest-section {
    margin-bottom: 40px;
  }

  .section-card {
    background: white;
    padding: 50px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0,0,0,0.05);
  }

  .section-card h2 {
    font-size: 2rem;
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 2px solid var(--color-bg-alt);
  }

  .market-item {
    margin-bottom: 35px;
  }

  .market-item h3 {
    font-size: 1.3rem;
    color: var(--color-text-main);
    margin-bottom: 15px;
  }

  .styled-list {
    list-style-type: none;
    padding-left: 0;
    margin-top: 15px;
  }

  .styled-list li {
    position: relative;
    padding-left: 25px;
    margin-bottom: 12px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .styled-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-primary);
    font-weight: bold;
  }

  .highlight-box {
    background: rgba(30, 90, 34, 0.05);
    padding: 20px;
    border-left: 4px solid var(--color-primary);
    border-radius: 0 8px 8px 0;
    margin-top: 25px;
    font-weight: 500;
    color: var(--color-primary);
  }

  .table-wrapper {
    overflow-x: auto;
    margin-top: 20px;
    border-radius: 8px;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.05);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  th, td {
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    line-height: 1.5;
  }

  th {
    background: var(--color-bg-alt);
    font-family: 'Outfit', sans-serif;
    color: var(--color-text-main);
    font-weight: 700;
  }

  .competitor-table td {
    color: var(--color-text-muted);
  }
  
  .competitor-table td strong {
    color: var(--color-text-main);
  }

  .mtpd-col {
    background: rgba(30, 90, 34, 0.03);
  }

  .mtpd-col.highlight {
    color: var(--color-primary);
    font-weight: 600;
  }

  .dark-card {
    background: var(--color-bg-alt);
    border-color: rgba(0,0,0,0.03);
  }

  .finance-table {
    background: white;
  }

  .finance-table td {
    color: var(--color-text-main);
  }

  .finance-table tfoot td {
    background: var(--color-primary);
    color: white;
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
  }

  .total-amount {
    font-weight: 800;
  }

  .cta-container {
    margin-top: 60px;
    text-align: center;
    background: white;
    padding: 40px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .btn-wa {
    display: inline-block;
    background: #25D366;
    color: white;
    padding: 16px 36px;
    border-radius: 50px;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    box-shadow: 0 10px 20px rgba(37, 211, 102, 0.3);
    transition: all 0.3s ease;
  }

  .btn-wa:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 25px rgba(37, 211, 102, 0.4);
  }

  @media (max-width: 768px) {
    .section-card {
      padding: 30px 20px;
    }
    
    .invest-header h1 {
      font-size: 2rem;
    }
    
    th, td {
      padding: 12px 15px;
      font-size: 0.9rem;
    }
  }
</style>
